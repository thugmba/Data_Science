        "---\n",
        "title: \"Data Science for Management Research\"\n",
        "subtitle: \"Case Study: Gogoro Green Product Customer Satisfaction and Loyalty\"\n",
        "format:\n",
        "  # html:\n",
        "  #   embed-resources: true\n",
        "  #   toc: true\n",
        "  #   number-sections: true\n",
        "  pdf:\n",
        "    toc: true\n",
        "    number-sections: true\n",
        "    colorlinks: true\n",
        "jupyter: python3\n",
        "execute:\n",
